{
  "compilerOptions": {
    "outDir": "dist",
    "module": "Node16",
    "target": "ES2020",
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "types": ["node", "jest"]
  }
}
